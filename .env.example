# Screenshot Service Configuration

# Interval between screenshots (e.g., 5m, 30s, 1h)
SCREENSHOT_INTERVAL=5m

# JPEG compression quality (1-100, lower = smaller file size)
JPEG_QUALITY=50

# RabbitMQ Configuration
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_EXCHANGE=worker-service-exchange
RABBITMQ_ROUTING_KEY=process-screenshot

# Note: Screenshots are only captured if user has been active 
# within the last 3 minutes (idle detection is automatic)
