# Activity Tracker Configuration
SCREENSHOT_INTERVAL=5m
JPEG_QUALITY=50
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_EXCHANGE=worker-service-exchange
RABBITMQ_ROUTING_KEY=process-screenshot

# Cricket Tracker Configuration
CRICKET_SCAN_INTERVAL=2s
CRICKET_RABBITMQ_EXCHANGE=worker-service-exchange
CRICKET_RABBITMQ_ROUTING_KEY=cricket-event

# OCR Mode: false = Local Windows OCR, true = Send images to LLM for analysis
CRICKET_USE_LLM_OCR=false

# Scoreboard coordinates for Cricket 24 (adjust based on your screen resolution)
# For 1920x1080 resolution - Expanded to capture player names above score bar
# This captures the full scoreboard including player names, scores, and stats
CRICKET_SCOREBOARD_X=0
CRICKET_SCOREBOARD_Y=850
CRICKET_SCOREBOARD_WIDTH=1920
CRICKET_SCOREBOARD_HEIGHT=230

# Alternative: Capture just the score area (top-left)
# CRICKET_SCOREBOARD_X=70
# CRICKET_SCOREBOARD_Y=35
# CRICKET_SCOREBOARD_WIDTH=100
# CRICKET_SCOREBOARD_HEIGHT=25

# Cricket game process names (comma-separated)
CRICKET_PROCESS_NAMES=Cricket24.exe,cricket.exe,Cricket 24.exe,Cricket24-Win64-Shipping.exe
